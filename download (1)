name: Nightly Trading Report

on:
  schedule:
    # 6:00 PM AWST = 10:00 UTC
    - cron: '0 10 * * 1-5'
  workflow_dispatch:   # allow manual trigger from GitHub UI

permissions:
  contents: write      # needed to push reports/latest.json and HTML to repo

jobs:
  run-report:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run trading analyser
        env:
          GMAIL_ADDRESS:      ${{ secrets.GMAIL_ADDRESS }}
          GMAIL_APP_PASSWORD: ${{ secrets.GMAIL_APP_PASSWORD }}
          REPORT_EMAIL:       ${{ secrets.REPORT_EMAIL }}
        run: python src/analyser.py

      - name: Regenerate dashboard HTML
        run: python src/build_dashboard.py

      - name: Commit and push report artifacts
        run: |
          git config user.name  "Trading Bot"
          git config user.email "bot@trading-analyser"
          git add reports/ index.html
          git diff --cached --quiet || git commit -m "Nightly report $(date +'%Y-%m-%d')"
          git push
